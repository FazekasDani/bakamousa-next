# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — local and secret overrides are ignored, shared defaults are committed
.env.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
Kimi_Agent_Bakamo Site Upgrade Code.zip

# TinaCMS
/tina/__generated__
/public/admin

# Confidential client reports — must never be served from /public
/public/media/Final Report-Migration_Integration.pdf
/public/media/ICPA 2020 Sept.pdf
